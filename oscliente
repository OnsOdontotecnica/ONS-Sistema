    function fecharModal() { document.getElementById('modalOS').classList.remove('active'); }
    function fecharModalAuditoria() { document.getElementById('modalAuditoria').classList.remove('active'); }
    
    function formatMoney(value) { return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value); }
    function parseMoneyToFloat(str) { if (!str) return 0; let cleaned = str.replace(/\./g, '').replace(',', '.').replace(/[^\d.-]/g, ''); return parseFloat(cleaned) || 0; }
    
    // ==================== LOCALSTORAGE ====================
    function salvarClientes() { localStorage.setItem('ons_clientes', JSON.stringify(clientes)); }
    function salvarManutencoes() { localStorage.setItem('ons_manutencoes', JSON.stringify(manutencoes)); }
    function salvarFaturas() { localStorage.setItem('ons_faturas', JSON.stringify(faturas)); }
    
    function carregarDadosLocais() {
        const c = localStorage.getItem('ons_clientes'); if (c) clientes = JSON.parse(c);
        const m = localStorage.getItem('ons_manutencoes'); if (m) manutencoes = JSON.parse(m);
        const f = localStorage.getItem('ons_faturas'); if (f) faturas = JSON.parse(f);
    }
    
    // ==================== DASHBOARD ====================
    function atualizarDashboard() {
        document.getElementById('total-clientes').textContent = clientes.length;
        document.getElementById('total-os-dash').textContent = manutencoes.length + osClientes.length;
        document.getElementById('total-andamento-dash').textContent = osClientes.filter(os => os.status !== 'Finalizado').length;
        document.getElementById('total-faturas-dash').textContent = faturas.length;
        
                                    const container = document.getElementById('lista-recentes');
        const recentes = [...manutencoes].reverse().slice(0, 5);
        if (recentes.length === 0) { container.innerHTML = '<div class="item-lista">Nenhuma OS recente</div>'; return; }
        container.innerHTML = recentes.map(os => {
            const cliente = clientes.find(c => c.id === os.clienteId);
            return `<div class="item-lista"><div><h4>${cliente?.nome || 'Cliente'} - ${os.equipamento}</h4><p><i class="fas fa-calendar"></i> ${new Date(os.data).toLocaleDateString()}</p></div><button class="btn-acao ver" onclick="verOSDetalhes(${os.id})">VER</button></div>`;
        }).join('');
    }
    
    // ==================== CLIENTES ====================
    window.salvarCliente = function() {
        const nome = document.getElementById('cliente-nome').value.trim();
        const telefone = document.getElementById('cliente-telefone').value.trim();
        if (!nome || !telefone) { mostrarNotificacao('Nome e telefone são obrigatórios!', 'erro'); return; }
        const novoCliente = { id: Date.now(), nome, telefone, email: document.getElementById('cliente-email').value, endereco: document.getElementById('cliente-endereco').value, data: new Date().toISOString() };
        clientes.push(novoCliente);
        salvarClientes();
        mostrarNotificacao('Cliente salvo!');
        limparFormCliente();
        carregarListaClientes();
        carregarClientesSelect();
        atualizarDashboard();
        carregarSelectOSFaturamento();
    };
    
    window.limparFormCliente = function() {
        document.getElementById('cliente-nome').value = '';
        document.getElementById('cliente-telefone').value = '';
        document.getElementById('cliente-email').value = '';
        document.getElementById('cliente-endereco').value = '';
    };
    
    function carregarListaClientes() {
        const container = document.getElementById('lista-clientes');
        if (clientes.length === 0) { container.innerHTML = '<div class="item-lista">Nenhum cliente cadastrado</div>'; return; }
        container.innerHTML = clientes.map(c => `
            <div class="item-lista">
                <div><h4>${c.nome}</h4><p><i class="fas fa-phone"></i> ${c.telefone}</p></div>
                <div><button class="btn-acao ver" onclick="verClienteCompleto(${c.id})">VER</button><button class="btn-acao editar" onclick="editarCliente(${c.id})">EDITAR</button><button class="btn-acao excluir" onclick="excluirCliente(${c.id})">EXCLUIR</button></div>
            </div>
        `).join('');
    }
    
    window.verClienteCompleto = function(id) {
        const cliente = clientes.find(c => c.id === id);
        document.getElementById('modal-body').innerHTML = `<p><strong>Nome:</strong> ${cliente.nome}</p><p><strong>Telefone:</strong> ${cliente.telefone}</p><p><strong>E-mail:</strong> ${cliente.email || 'N/A'}</p><p><strong>Endereço:</strong> ${cliente.endereco || 'N/A'}</p>`;
        document.getElementById('modalOS').classList.add('active');
    };
    
    window.editarCliente = function(id) {
        const cliente = clientes.find(c => c.id === id);
        if (cliente) {
            document.getElementById('cliente-nome').value = cliente.nome;
            document.getElementById('cliente-telefone').value = cliente.telefone;
            document.getElementById('cliente-email').value = cliente.email || '';
            document.getElementById('cliente-endereco').value = cliente.endereco || '';
            clientes = clientes.filter(c => c.id !== id);
            salvarClientes();
            mostrarNotificacao('Edite e clique em Salvar');
            carregarListaClientes();
            carregarClientesSelect();
        }
    };
    
    window.excluirCliente = function(id) {
        if (!confirm('Excluir cliente? Todas as OS serão perdidas!')) return;
        clientes = clientes.filter(c => c.id !== id);
        manutencoes = manutencoes.filter(m => m.clienteId !== id);
        salvarClientes();
        salvarManutencoes();
        carregarListaClientes();
        carregarClientesSelect();
        atualizarDashboard();
        carregarSelectOSFaturamento();
        mostrarNotificacao('Cliente excluído!');
    };
    
    function carregarClientesSelect() {
        const select = document.getElementById('os-cliente');
        select.innerHTML = '<option value="">Selecione um cliente</option>';
        clientes.forEach(c => select.innerHTML += `<option value="${c.id}">${c.nome}</option>`);
    }
    
    // ==================== EQUIPAMENTOS ====================
    function mostrarEquipamentos() {
        const container = document.getElementById('lista-equipamentos-pre');
        const lista = ['Cadeira Odontológica', 'Compressor', 'Autoclave', 'Raio-X', 'Caneta Alta Rotação', 'Ultrassom', 'Fotopolimerizadora', 'Motor Elétrico'];
        container.innerHTML = lista.map(eq => `<button class="btn btn-outline" onclick="selecionarEquipamento('${eq}')">${eq}</button>`).join('');
    }
    
    window.selecionarEquipamento = function(equipamento) {
        document.getElementById('os-equipamento').value = equipamento;
        // Muda para aba Nova OS
        document.querySelector('[data-tela="novaos"]').click();
    };
    
    window.usarEquipamentoManual = function() {
        const eq = document.getElementById('equip-manual').value.trim();
        if (eq) { document.getElementById('os-equipamento').value = eq; document.querySelector('[data-tela="novaos"]').click(); }
        else mostrarNotificacao('Digite um equipamento!', 'erro');
    };
    
    // ==================== OS ====================
    window.salvarOS = function() {
        const clienteId = document.getElementById('os-cliente').value;
        const equipamento = document.getElementById('os-equipamento').value.trim();
        if (!clienteId || !equipamento) { mostrarNotificacao('Preencha todos os campos!', 'erro'); return; }
        manutencoes.push({ id: Date.now(), clienteId: parseInt(clienteId), equipamento, defeitos: document.getElementById('os-defeitos').value, solucoes: document.getElementById('os-solucoes').value, data: new Date().toISOString() });
        salvarManutencoes();
        mostrarNotificacao('OS salva!');
        limparOS();
        atualizarDashboard();
        carregarHistorico();
        carregarSelectOSFaturamento();
    };
    
    window.limparOS = function() {
        document.getElementById('os-cliente').value = '';
        document.getElementById('os-equipamento').value = '';
        document.getElementById('os-defeitos').value = '';
        document.getElementById('os-solucoes').value = '';
    };
    
    function carregarHistorico() {
        const container = document.getElementById('lista-historico');
        if (manutencoes.length === 0) { container.innerHTML = '<div class="item-lista">Nenhuma OS</div>'; return; }
        container.innerHTML = [...manutencoes].reverse().map(os => {
            const cliente = clientes.find(c => c.id === os.clienteId);
            return `<div class="item-lista"><div><h4>${cliente?.nome || 'N/A'} - ${os.equipamento}</h4><p><i class="fas fa-calendar"></i> ${new Date(os.data).toLocaleDateString()}</p></div><button class="btn-acao ver" onclick="verOSDetalhes(${os.id})">VER</button><button class="btn-acao excluir" onclick="excluirOSLocal(${os.id})">EXCLUIR</button></div>`;
        }).join('');
    }
    
    window.verOSDetalhes = function(id) {
        const os = manutencoes.find(m => m.id === id);
        const cliente = clientes.find(c => c.id === os?.clienteId);
        document.getElementById('modal-body').innerHTML = `<p><strong>Cliente:</strong> ${cliente?.nome}</p><p><strong>Equipamento:</strong> ${os?.equipamento}</p><p><strong>Defeito:</strong> ${os?.defeitos || 'N/A'}</p><p><strong>Solução:</strong> ${os?.solucoes || 'N/A'}</p><p><strong>Data:</strong> ${new Date(os?.data).toLocaleString()}</p>`;
        document.getElementById('modalOS').classList.add('active');
    };
    
    window.excluirOSLocal = function(id) {
        if (!confirm('Excluir OS?')) return;
        manutencoes = manutencoes.filter(m => m.id !== id);
        salvarManutencoes();
        carregarHistorico();
        atualizarDashboard();
        carregarSelectOSFaturamento();
    };
    
    function listarTodasOS() {
        const container = document.getElementById('lista-todas-os');
        if (manutencoes.length === 0) { container.innerHTML = '<div class="item-lista">Nenhuma OS</div>'; return; }
        container.innerHTML = [...manutencoes].reverse().map(os => {
            const cliente = clientes.find(c => c.id === os.clienteId);
            return `<div class="item-lista"><div><strong>${cliente?.nome || '?'}</strong> - ${os.equipamento}<br><small>${new Date(os.data).toLocaleString()}</small></div></div>`;
        }).join('');
    }
    
    // ==================== FATURAMENTO ====================
    function carregarSelectOSFaturamento() {
        const select = document.getElementById('faturamento-os-select');
        select.innerHTML = '<option value="">Selecione uma OS</option>';
        manutencoes.forEach(os => {
            const cliente = clientes.find(c => c.id === os.clienteId);
            select.innerHTML += `<option value="${os.id}">${cliente?.nome || 'Cliente'} - ${os.equipamento}</option>`;
        });
        select.onchange = function() {
            const osId = parseInt(this.value);
            if (osId) {
                osSelecionadaFatura = manutencoes.find(m => m.id === osId);
                document.getElementById('dados-faturamento').style.display = 'block';
                document.getElementById('num-documento').value = `OS-${osId}-${new Date().getFullYear()}`;
                document.getElementById('fatura-valor').value = '350,00';
            } else {
                document.getElementById('dados-faturamento').style.display = 'none';
            }
        };
    }
    
    window.salvarFatura = function() {
        if (!osSelecionadaFatura) { mostrarNotificacao('Selecione uma OS primeiro!', 'erro'); return; }
        const valor = parseMoneyToFloat(document.getElementById('fatura-valor').value) || 350;
        const pagamento = document.querySelector('input[name="pagamento-tipo"]:checked').value;
        const novaFatura = { id: Date.now(), osId: osSelecionadaFatura.id, clienteId: osSelecionadaFatura.clienteId, numeroDocumento: document.getElementById('num-documento').value, valorTotal: valor, formaPagamento: pagamento, status: 'EM ABERTO', data: new Date().toISOString() };
        faturas.push(novaFatura);
        salvarFaturas();
        mostrarNotificacao('Fatura salva!');
        atualizarDashboard();
    };
    
    window.imprimirDocumento = function() {
        if (!osSelecionadaFatura) { mostrarNotificacao('Selecione uma OS!', 'erro'); return; }
        const fatura = faturas.find(f => f.osId === osSelecionadaFatura.id);
        const cliente = clientes.find(c => c.id === osSelecionadaFatura.clienteId);
        const html = `<div style="padding:20px"><h2>ONS SOLUÇÕES E ELETROTÉCNICA</h2><p>Documento: ${document.getElementById('num-documento').value}</p><p>Cliente: ${cliente?.nome}</p><p>Equipamento: ${osSelecionadaFatura.equipamento}</p><p>Valor: ${formatMoney(fatura?.valorTotal || 350)}</p><p>Pagamento: ${document.querySelector('input[name="pagamento-tipo"]:checked').value}</p></div>`;
        const win = window.open('', '_blank');
        win.document.write(`<html><head><title>Fatura ONS</title></head><body>${html}</body></html>`);
        win.print();
    };
    
    window.enviarFaturaWhatsApp = function() {
        if (!osSelecionadaFatura) { mostrarNotificacao('Selecione uma OS!', 'erro'); return; }
        const cliente = clientes.find(c => c.id === osSelecionadaFatura.clienteId);
        if (cliente?.telefone) window.open(`https://wa.me/55${cliente.telefone.replace(/\D/g, '')}?text=Fatura%20ONS%20disponível`, '_blank');
        else mostrarNotificacao('Telefone não encontrado', 'erro');
    };
    
    // ==================== ORÇAMENTO ====================
    function atualizarTotalOrcamento() {
        const mao = parseMoneyToFloat(document.getElementById('orcMaoDeObra').value);
        const pecas = parseMoneyToFloat(document.getElementById('orcPecasValor').value);
        document.getElementById('orcTotalGeralSpan').textContent = formatMoney(mao + pecas);
    }
    document.getElementById('orcMaoDeObra').addEventListener('input', atualizarTotalOrcamento);
    document.getElementById('orcPecasValor').addEventListener('input', atualizarTotalOrcamento);
    
    window.gerarOrcamentoCompleto = function() {
        const nome = document.getElementById('orcClienteNome').value.trim();
        const telefone = document.getElementById('orcClienteTelefone').value.trim();
        if (!nome || !telefone) { mostrarNotificacao('Preencha nome e telefone!', 'erro'); return; }
        const tipo = document.querySelector('input[name="orcTipoServico"]:checked').value;
        const detalhes = document.getElementById('orcDetalhesProposta').value;
        const maoDeObra = parseMoneyToFloat(document.getElementById('orcMaoDeObra').value);
        const pecas = parseMoneyToFloat(document.getElementById('orcPecasValor').value);
        const total = maoDeObra + pecas;
        
        const html = `<div style="background:#fff4e0; border:3px solid #0a2f44; padding:20px; border-radius:16px;"><h2 style="color:#0a2f44;">ONS SOLUÇÕES E ELETROTÉCNICA</h2><p><strong>Cliente:</strong> ${nome}<br><strong>Telefone:</strong> ${telefone}<br><strong>Tipo:</strong> ${tipo === 'manutencao' ? 'MANUTENÇÃO' : 'INSTALAÇÃO'}</p><p><strong>Serviço:</strong> ${detalhes || 'Conforme descrito'}</p><hr><p><strong>Mão de obra:</strong> ${formatMoney(maoDeObra)}<br><strong>Peças:</strong> ${formatMoney(pecas)}</p><div style="font-size:1.5rem; text-align:right; margin-top:16px;"><strong>TOTAL: ${formatMoney(total)}</strong></div><div style="margin-top:20px; font-size:0.7rem; text-align:center;">Garantia de 90 dias • ONS Eletrotécnica</div></div>`;
        document.getElementById('previewOrcamento').innerHTML = html;
        document.getElementById('previewOrcamento').style.display = 'block';
    };
    
    window.imprimirOrcamento = function() {
        const conteudo = document.getElementById('previewOrcamento').innerHTML;
        if (!conteudo) { mostrarNotificacao('Gere o orçamento primeiro!', 'erro'); return; }
        const win = window.open('', '_blank');
        win.document.write(`<html><head><title>Orçamento ONS</title></head><body>${conteudo}</body></html>`);
        win.print();
    };
    
    window.enviarOrcamentoWhatsApp = function() {
        const telefone = document.getElementById('orcClienteTelefone').value.replace(/\D/g, '');
        if (telefone) window.open(`https://wa.me/55${telefone}?text=Orçamento%20ONS%20disponível!`, '_blank');
        else mostrarNotificacao('Telefone inválido!', 'erro');
    };
    
  // ==================== OS CLIENTES (SUPABASE) ====================
window.carregarOSClientes = async function() {
    mostrarNotificacao('Carregando OS do app...');
    try {
        const { data, error } = await supabase.from('chamados').select('*').order('created_at', { ascending: false });
        if (error) throw error;
        osClientes = data || [];
        document.getElementById('total-os-clientes').textContent = osClientes.length;
        document.getElementById('total-os-andamento').textContent = osClientes.filter(os => os.status !== 'Finalizado').length;
        document.getElementById('total-os-finalizadas').textContent = osClientes.filter(os => os.status === 'Finalizado').length;
        
        const container = document.getElementById('lista-os-clientes');
        if (osClientes.length === 0) { 
            container.innerHTML = '<div class="item-lista">Nenhuma OS do aplicativo</div>'; 
            return; 
        }
        
        container.innerHTML = osClientes.map(os => `
            <div class="item-lista">
                <div>
                    <strong>${os.clinica}</strong> - ${os.equipamento}
                    <br>
                    <span style="background:${os.status === 'Finalizado' ? '#2c7a4d' : '#e8a317'}; color:white; padding:2px 8px; border-radius:20px; font-size:0.6rem; display:inline-block; margin-top:4px;">
                        ${os.status || 'Em andamento'}
                    </span>
                </div>
                <div style="display: flex; gap: 5px; flex-wrap: wrap; margin-top: 8px;">
                    <button class="btn-acao" onclick="atualizarStatusOS(${os.id}, 'Em andamento')">🔄 Andamento</button>
                    <button class="btn-acao" onclick="atualizarStatusOS(${os.id}, 'Finalizado')">✅ Finalizar</button>
                    <button class="btn-acao wpp" onclick="enviarWhatsAppOS(${os.id})"><i class="fab fa-whatsapp"></i> WhatsApp</button>
                </div>
            </div>
        `).join('');
        
        mostrarNotificacao(`${osClientes.length} OS carregadas`);
    } catch (err) { 
        mostrarNotificacao('Erro ao carregar OS: ' + err.message, 'erro'); 
        console.error(err);
    }
};
    
    window.enviarWhatsAppOS = function(id) {
        const os = osClientes.find(o => o.id === id);
        if (os?.telefone_cliente) window.open(`https://wa.me/55${os.telefone_cliente.replace(/\D/g, '')}?text=OS%20${os.id}%20-%20${os.equipamento}`, '_blank');
        else mostrarNotificacao('Telefone não encontrado', 'erro');
    };
    
    window.enviarMsgParaTodos = function() {
        const msg = prompt('Digite a mensagem:', 'ONS Soluções - Seu equipamento está pronto!');
        if (msg) osClientes.forEach(os => { if (os.telefone_cliente) window.open(`https://wa.me/55${os.telefone_cliente.replace(/\D/g, '')}?text=${encodeURIComponent(msg)}`, '_blank'); });
    };
    
    // ==================== AUDITORIA ====================
    function gerarResumoAuditoria() {
        let totalOS = manutencoes.length + osClientes.length;
        let totalFaturado = faturas.reduce((sum, f) => sum + f.valorTotal, 0);
        let totalEmAberto = faturas.filter(f => f.status === 'EM ABERTO').reduce((sum, f) => sum + f.valorTotal, 0);
        let html = `<div><strong>ONS SOLUÇÕES E ELETROTÉCNICA</strong><hr><p>Total de OS: ${totalOS}</p><p>Total de Faturas: ${faturas.length}</p><p>Total Faturado: ${formatMoney(totalFaturado)}</p><p>Em Aberto: ${formatMoney(totalEmAberto)}</p></div>`;
        let txtResumo = `ONS AUDITORIA\nTotal OS: ${totalOS}\nTotal Faturado: R$ ${totalFaturado.toFixed(2)}`;
        return { html, txtResumo };
    }
    
    window.abrirAuditoria = function() {
        const { html } = gerarResumoAuditoria();
        document.getElementById('conteudo-auditoria').innerHTML = html;
        document.getElementById('modalAuditoria').classList.add('active');
    };
    
    window.exportarAuditoriaTXT = function() {
        const { txtResumo } = gerarResumoAuditoria();
        const blob = new Blob([txtResumo], { type: 'text/plain' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `auditoria_ons_${new Date().toISOString().slice(0, 10)}.txt`;
        link.click();
        mostrarNotificacao('Arquivo TXT gerado!');
    };
    
    window.enviarAuditoriaWhatsApp = function() {
        const { txtResumo } = gerarResumoAuditoria();
        const numero = prompt('Digite o número do WhatsApp (com DDD):');
        if (numero) window.open(`https://wa.me/55${numero.replace(/\D/g, '')}?text=${encodeURIComponent(txtResumo)}`, '_blank');
    };

    // ==================== ATUALIZAR STATUS OS (SUPABASE) ====================
window.atualizarStatusOS = async function(id, novoStatus) {
    try {
        const { error } = await supabase
            .from('chamados')
            .update({ status: novoStatus })
            .eq('id', id);
        
        if (error) throw error;
        mostrarNotificacao(`Status alterado para ${novoStatus}!`);
        carregarOSClientes();
    } catch (err) {
        mostrarNotificacao('Erro ao atualizar status: ' + err.message, 'erro');
    }
};
    // ==================== INSTALAÇÕES ====================
    function carregarInstalacoes() {
        const container = document.getElementById('lista-instalacoes');
        container.innerHTML = `
            <div class="item-lista"><i class="fas fa-check-circle"></i> App instalado: ${window.matchMedia('(display-mode: standalone)').matches ? 'SIM' : 'NÃO'}</div>
            <div class="item-lista"><i class="fas fa-download"></i> Para instalar: Menu do navegador → "Instalar aplicativo"</div>
            <div class="item-lista"><i class="fas fa-sync-alt"></i> Service Worker: ${'serviceWorker' in navigator ? 'Suportado' : 'Não suportado'}</div>
        `;
        document.getElementById('total-instalacoes').textContent = '3';
    }
    
    // ==================== SERVICE WORKER E PWA ====================
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').then(reg => {
            console.log('Service Worker registrado!', reg);
            document.getElementById('pwa-status').innerHTML = '✅ PWA Ativo';
        }).catch(err => {
            console.log('Service Worker erro:', err);
            document.getElementById('pwa-status').innerHTML = '⚠️ PWA não registrado';
        });
    } else {
        document.getElementById('pwa-status').innerHTML = '❌ Service Worker não suportado';
    }
    
    // Verifica se já está instalado
    if (window.matchMedia('(display-mode: standalone)').matches) {
        document.getElementById('pwa-status').innerHTML = '📱 App instalado e rodando';
    }
    
    // ==================== LOGO ====================
    function carregarLogoSaved() {
        const logoSalva = localStorage.getItem('ons_logo');
        if (logoSalva) {
            document.getElementById('logoDisplay').innerHTML = `<img src="${logoSalva}" class="logo-imagem" style="height: 40px;">`;
        }
    }
    
    document.getElementById('logoUpload')?.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(event) {
                document.getElementById('logoDisplay').innerHTML = `<img src="${event.target.result}" class="logo-imagem" style="height: 40px;">`;
                localStorage.setItem('ons_logo', event.target.result);
                mostrarNotificacao('Logo alterada!');
            };
            reader.readAsDataURL(file);
        }
    });
    
    // ==================== MENU - CORRIGIDO ====================
    document.querySelectorAll('.menu-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            // Remove active de todos
            document.querySelectorAll('.menu-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            // Adiciona active no botão clicado
            this.classList.add('active');
            const telaId = this.getAttribute('data-tela');
            const secao = document.getElementById(telaId);
            if (secao) {
                secao.classList.add('active');
            } else {
                console.error('Seção não encontrada:', telaId);
            }
            // Carrega dados específicos
            if (telaId === 'dashboard') atualizarDashboard();
            if (telaId === 'clientes') carregarListaClientes();
            if (telaId === 'equipamentos') mostrarEquipamentos();
            if (telaId === 'historico') carregarHistorico();
            if (telaId === 'relatorios') listarTodasOS();
            if (telaId === 'faturamento') carregarSelectOSFaturamento();
            if (telaId === 'osclientes') carregarOSClientes();
            if (telaId === 'instalacoes') carregarInstalacoes();
        });
    });
    
    // ==================== INIT ====================
    document.addEventListener('DOMContentLoaded', () => {
        carregarDadosLocais();
        carregarLogoSaved();
        carregarClientesSelect();
        carregarListaClientes();
        mostrarEquipamentos();
        carregarHistorico();
        carregarOSClientes();
        atualizarDashboard();
        carregarSelectOSFaturamento();
        listarTodasOS();
        carregarInstalacoes();
        atualizarTotalOrcamento();
        document.getElementById('status-conexao').innerHTML = '✅ Supabase Conectado';
        console.log('Sistema inicializado com sucesso!');
