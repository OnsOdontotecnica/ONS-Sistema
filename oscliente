<script>
    // ==================== CONFIGURAÇÕES ====================
    const SUPABASE_URL = 'https://vckyxwonbpkdeqeoswxc.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZja3l4d29uYnBrZGVxZW9zd3hjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwMTY5NjMsImV4cCI6MjA5MTU5Mjk2M30.b5ni_vnIETHVuOs5Cy4982UUBq9Icm-Zc12W1FwQyvI';
    const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    
    let clientes = [], manutencoes = [], osClientes = [], faturas = [];
    let osSelecionadaFatura = null;
    
    // ==================== NOTIFICAÇÕES ====================
    function mostrarNotificacao(msg, tipo = 'sucesso') {
        const n = document.getElementById('notificacao');
