<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>ONS SOLUÇÕES E ELETROTÉCNICA - Sistema Vintage</title>
    <meta name="theme-color" content="#0a2f44">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="ONS Eletro">
    <link rel="manifest" href="manifest.json">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Courier New', 'Fira Code', monospace; -webkit-tap-highlight-color: transparent; }
        :root {
            --azul-80: #0a2f44;
            --dourado-80: #d4a017;
            --creme: #f5e6c8;
            --bege: #e8dcc8;
            --sombra-80: 5px 5px 0px rgba(0,0,0,0.2);
        }
        body { background: linear-gradient(135deg, #c9c9a5 0%, #b8b894 100%); min-height: 100vh; padding: 12px; }
        .container { max-width: 1400px; margin: 0 auto; }
        
        /* HEADER - OTIMIZADO PARA MOBILE */
        .header { background: var(--azul-80); border: 3px solid var(--dourado-80); padding: 12px 16px; margin-bottom: 16px; box-shadow: var(--sombra-80); border-radius: 8px; }
        .header-content { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
        .logo-ons { background: var(--dourado-80); color: var(--azul-80); padding: 8px 16px; font-weight: 900; font-size: 0.9rem; cursor: pointer; border: 2px solid #fff8e7; box-shadow: 4px 4px 0 rgba(0,0,0,0.3); display: inline-flex; align-items: center; gap: 8px; border-radius: 8px; }
        .logo-imagem { height: 40px; width: auto; }
        .title-section h1 { font-size: 0.8rem; color: var(--dourado-80); text-transform: uppercase; }
        .title-section p { font-size: 0.55rem; color: #f0e6c5; }
        .header-telefone { background: #00000055; padding: 4px 12px; border-left: 4px solid var(--dourado-80); color: var(--dourado-80); font-weight: bold; font-size: 0.7rem; border-radius: 8px; }
        
        /* MENU - SCROLL HORIZONTAL PARA MOBILE */
        .menu { display: flex; flex-wrap: nowrap; overflow-x: auto; gap: 8px; margin-bottom: 16px; background: var(--creme); padding: 10px 12px; border: 2px solid var(--azul-80); box-shadow: var(--sombra-80); border-radius: 12px; -webkit-overflow-scrolling: touch; scrollbar-width: thin; }
        .menu::-webkit-scrollbar { height: 4px; }
        .menu-btn { background: #fef6e0; border: 2px solid var(--azul-80); padding: 8px 14px; font-weight: 800; color: var(--azul-80); cursor: pointer; display: inline-flex; align-items: center; gap: 6px; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; transition: 0.1s ease; box-shadow: 2px 2px 0 rgba(0,0,0,0.1); border-radius: 8px; white-space: nowrap; }
        .menu-btn:active { transform: scale(0.96); }
        .menu-btn.active { background: var(--azul-80); color: var(--dourado-80); border-color: var(--dourado-80); }
        
        /* SEÇÕES */
        .section { background: var(--bege); border: 3px solid var(--azul-80); padding: 16px; display: none; box-shadow: var(--sombra-80); border-radius: 12px; animation: fadeIn 0.2s; }
        .section.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(8px);} to { opacity: 1; transform: translateY(0);} }
        
        .titulo-secao { color: var(--azul-80); border-left: 8px solid var(--dourado-80); padding-left: 12px; margin-bottom: 16px; font-size: 1rem; font-weight: 900; text-transform: uppercase; }
        
        /* CARDS - GRID RESPONSIVO */
        .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-bottom: 20px; }
        .card-dash { background: #fffef5; border: 2px solid var(--azul-80); padding: 12px 8px; text-align: center; box-shadow: 4px 4px 0 rgba(0,0,0,0.1); border-radius: 12px; }
        .card-dash h3 { font-size: 1.6rem; color: var(--azul-80); font-weight: 900; }
        .card-dash p { font-size: 0.7rem; }
        
        /* BOTÕES - MAIOR ÁREA DE TOQUE */
        .btn { padding: 10px 16px; border: 2px solid var(--azul-80); font-weight: 800; cursor: pointer; font-size: 0.75rem; text-transform: uppercase; background: #fff2df; transition: 0.1s ease; box-shadow: 2px 2px 0 rgba(0,0,0,0.1); margin: 4px; border-radius: 10px; min-height: 44px; }
        .btn:active { transform: scale(0.96); }
        .btn-primario { background: var(--azul-80); color: var(--dourado-80); border-color: var(--dourado-80); }
        .btn-dourado { background: var(--dourado-80); color: var(--azul-80); border-color: var(--azul-80); }
        .btn-outline { background: #f0e6d2; border: 2px solid var(--azul-80); }
        
        /* FORMULÁRIOS */
        input, select, textarea { width: 100%; padding: 12px; border: 2px solid var(--azul-80); background: #fffff2; font-family: monospace; margin-bottom: 12px; border-radius: 10px; font-size: 16px; }
        .form-group { margin-bottom: 12px; }
        .form-group label { font-weight: 800; color: var(--azul-80); display: block; margin-bottom: 5px; font-size: 0.7rem; text-transform: uppercase; }
        
        /* LISTAS */
        .lista-container { max-height: 450px; overflow-y: auto; border: 1px solid var(--azul-80); background: #fffef7; border-radius: 12px; -webkit-overflow-scrolling: touch; }
        .item-lista { padding: 14px; border-bottom: 1px solid #c0b89a; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
        
        /* BOTÕES DE AÇÃO */
        .btn-acao { padding: 8px 14px; border: 1px solid var(--azul-80); font-weight: bold; cursor: pointer; font-size: 0.7rem; margin: 2px; background: #e9ddc7; border-radius: 8px; min-height: 40px; }
        .btn-acao:active { transform: scale(0.95); }
        
        /* MODAIS */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; justify-content: center; align-items: center; }
        .modal.active { display: flex; }
        .modal-content { background: #fdf3e0; border: 4px solid var(--azul-80); max-width: 600px; width: 90%; padding: 20px; box-shadow: 12px 12px 0 rgba(0,0,0,0.2); border-radius: 16px; max-height: 80vh; overflow-y: auto; }
        
        /* NOTIFICAÇÃO */
        .notificacao { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: var(--azul-80); color: var(--dourado-80); padding: 12px 20px; text-align: center; font-weight: bold; border: 2px solid var(--dourado-80); z-index: 2000; border-radius: 50px; white-space: nowrap; }
        .hidden { display: none; }
        
        @media (max-width: 600px) { body { padding: 8px; } .menu-btn { padding: 6px 10px; font-size: 0.6rem; } .section { padding: 12px; } }
        @media (min-width: 768px) and (max-width: 1024px) { .cards-grid { grid-template-columns: repeat(4, 1fr); } .menu { flex-wrap: wrap; overflow-x: visible; justify-content: center; } }
    </style>
</head>
<body>
